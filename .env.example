# Copy this file to `.env` for local development.
# Only `VITE_*` variables are exposed to the client.
# Set this to your production origin before deploying so canonical tags,
# social metadata, robots.txt, and sitemap.xml point at the real site.
VITE_SITE_URL=https://promptrc.app

# Clerk authentication.
VITE_CLERK_PUBLISHABLE_KEY=pk_test_your_publishable_key
CLERK_SECRET_KEY=sk_test_your_secret_key
