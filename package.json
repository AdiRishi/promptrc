{
  "name": "promptrc",
  "description": "A terminal-inspired prompt library for storing, searching, and reusing your best AI prompts.",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite dev --port 8080",
    "build": "vite build",
    "cf-typegen": "pnpm build && wrangler types worker-configuration.d.ts --config .output/server/wrangler.json",
    "preview": "vite preview",
    "deploy": "wrangler --cwd .output deploy",
    "deploy:dry-run": "wrangler --cwd .output deploy --dry-run",
    "db:migrate": "wrangler d1 migrations apply promptrc --local",
    "test": "vitest run --coverage",
    "typecheck": "pnpm cf-typegen && tsc --noEmit && tsc --project tests/tsconfig.json --noEmit",
    "lint": "eslint",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "check": "pnpm format:check && pnpm lint && pnpm typecheck && pnpm deploy:dry-run"
  },
  "dependencies": {
    "@base-ui/react": "^1.4.1",
    "@clerk/tanstack-react-start": "^1.2.3",
    "@clerk/ui": "^1.9.1",
    "@fontsource-variable/inter": "^5.2.8",
    "@fontsource-variable/jetbrains-mono": "^5.2.8",
    "@tailwindcss/vite": "^4.3.0",
    "@tanstack/react-devtools": "^0.10.5",
    "@tanstack/react-query": "^5.100.10",
    "@tanstack/react-query-devtools": "^5.100.10",
    "@tanstack/react-router": "^1.169.2",
    "@tanstack/react-router-devtools": "^1.166.13",
    "@tanstack/react-router-ssr-query": "^1.166.12",
    "@tanstack/react-start": "^1.167.65",
    "@tanstack/router-plugin": "^1.167.35",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.14.0",
    "next-themes": "^0.4.6",
    "nitro": "^3.0.260429-beta",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-icons": "^5.6.0",
    "react-markdown": "^10.1.0",
    "remark-breaks": "^4.0.0",
    "remark-gfm": "^4.0.1",
    "shadcn": "^4.7.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.3.0",
    "tw-animate-css": "^1.4.0",
    "zustand": "^5.0.13"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.16.4",
    "@tanstack/devtools-vite": "^0.7.0",
    "@tanstack/eslint-config": "^0.4.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@trivago/prettier-plugin-sort-imports": "^6.0.2",
    "@types/node": "^25.7.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-istanbul": "^4.1.6",
    "eslint": "^10.3.0",
    "eslint-config-prettier": "^10.1.8",
    "jsdom": "^29.1.1",
    "prettier": "^3.8.3",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.12",
    "vitest": "^4.1.6",
    "web-vitals": "^5.2.0",
    "wrangler": "^4.90.1"
  },
  "packageManager": "pnpm@11.1.1"
}
